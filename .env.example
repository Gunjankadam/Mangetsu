# Copy to `.env` for local Vite. Do not commit real values.

# Optional: default manga API origin for static builds (no trailing slash).
# VITE_MANGA_FLOW_BACKEND_URL=https://your-api.example.com

# Optional: Supabase (cloud auth / sync).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Optional: user backend override.
# VITE_USER_BACKEND_URL=
